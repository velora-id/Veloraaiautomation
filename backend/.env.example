# Application
APP_NAME=Velora AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
API_V1_STR=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Database
# Docker Compose backend service:
DATABASE_URL=postgresql+asyncpg://velora:velora_password@postgres:5432/velora_db
# Local Python process with Docker Postgres port exposed:
# DATABASE_URL=postgresql+asyncpg://velora:velora_password@localhost:5432/velora_db
# Local lightweight SQLite fallback:
# DATABASE_URL=sqlite+aiosqlite:///./velora.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Security
SECRET_KEY=change-this-to-a-random-32-character-or-longer-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174"]

# AI APIs
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
